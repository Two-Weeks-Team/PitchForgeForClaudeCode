{
  "$schema_version": "0.1.0",
  "name": "story-300s",
  "runtime_seconds": 300,
  "description": "Three-act narrative with a protagonist. For 5-minute keynotes and conference talks. Act I sets up who and what's at stake; Act II is the protagonist's confrontation with the problem; Act III is resolution + reflection. Hero copy lands at the end of Act I and echoes at the end of Act III.",
  "hero_copy_placement": ["F4_primary", "F11_echo"],
  "color_arc": [
    {"frame_id": "cover", "palette_role": "hero"},
    {"frame_id": "F1",    "palette_role": "problem"},
    {"frame_id": "F2",    "palette_role": "failure"},
    {"frame_id": "F3",    "palette_role": "pivot"},
    {"frame_id": "F4",    "palette_role": "hero"},
    {"frame_id": "F5",    "palette_role": "problem"},
    {"frame_id": "F6",    "palette_role": "architecture"},
    {"frame_id": "F7",    "palette_role": "pivot"},
    {"frame_id": "F8",    "palette_role": "problem"},
    {"frame_id": "F9",    "palette_role": "pivot"},
    {"frame_id": "F10",   "palette_role": "payoff"},
    {"frame_id": "F11",   "palette_role": "hero"},
    {"frame_id": "close", "palette_role": "pivot"}
  ],
  "beats": [
    {"frame_id": "cover", "position": 1,  "shape": "cover",                "act": "cover",  "time_start_seconds": 0,   "duration_seconds": 12, "concept": "Title card · who is the protagonist?", "stock_heading": "{{project_name}}", "stock_voiceover": "", "show_echo_ribbon": false, "delivery_note": "Long hold. The audience reads.", "tone_note": "title-card calm"},
    {"frame_id": "F1",    "position": 2,  "shape": "chain",                "act": "agro",   "time_start_seconds": 12,  "duration_seconds": 18, "concept": "Act I · setup — who, where, what's at stake", "stock_heading": "we don't know what we want.", "stock_heading_accent_word": "want.", "stock_meta_tag": "act i · setup", "stock_script_h2": "Where the story starts.", "stock_voiceover": "Here's the lie we tell every project. 'I know what I want.' You don't. <b>Not until you see it.</b>", "show_echo_ribbon": false, "delivery_note": "Set scene calmly. No urgency yet.", "tone_note": "narrator establishing"},
    {"frame_id": "F2",    "position": 3,  "shape": "stack-strikethrough",  "act": "agro",   "time_start_seconds": 30,  "duration_seconds": 25, "concept": "Act I · the failed attempts", "stock_heading": "every. single. time.", "stock_heading_accent_word": "time.", "stock_meta_tag": "act i · failed attempts", "stock_script_h2": "The cycle.", "stock_voiceover": "Tests pass. Specs lock. Product wrong. <b>Every. Single. Time.</b>", "show_echo_ribbon": false, "delivery_note": "Cycle of failure. Each fragment a beat.", "tone_note": "indictment"},
    {"frame_id": "F3",    "position": 4,  "shape": "chain",                "act": "drop",   "time_start_seconds": 55,  "duration_seconds": 15, "concept": "Act I close · the realization", "stock_heading": "flip the order.", "stock_heading_accent_word": "flip", "stock_meta_tag": "act i close · the realization", "stock_script_h2": "Result first.", "stock_voiceover": "So we flipped it. See the result <i>first</i> — before any spec. <b>The picture is the spec.</b>", "show_echo_ribbon": false, "delivery_note": "Em-dash held breath. Then quiet.", "tone_note": "maker who figured it out"},
    {"frame_id": "F4",    "position": 5,  "shape": "gallery-hero",         "act": "drop",   "time_start_seconds": 70,  "duration_seconds": 25, "concept": "Act I climax · hero gallery", "stock_voiceover": "Twenty-six futures of your idea. Before any spec. <b>{{hero_copy}}</b>", "show_echo_ribbon": false, "navbar_keys_label": "★ ACT I CLIMAX · hero lands · 25s hold", "delivery_note": "Hero slowly. Each syllable. Half-beat after.", "tone_note": "keynote reveal"},
    {"frame_id": "F5",    "position": 6,  "shape": "counter-roll",         "act": "thrill", "time_start_seconds": 95,  "duration_seconds": 10, "concept": "Act II open · the scale", "stock_meta_tag": "act ii · the kick", "stock_script_h2": "The scale.", "stock_voiceover": "How? <b>{{counter_target}} {{counter_unit}}. One plugin. Two clicks.</b>", "show_echo_ribbon": true, "delivery_note": "Audience question. Then snap the number.", "tone_note": "rule-of-three confidence"},
    {"frame_id": "F6",    "position": 7,  "shape": "hierarchy-diagram",    "act": "thrill", "time_start_seconds": 105, "duration_seconds": 30, "concept": "Act II · architecture", "stock_meta_tag": "act ii · architecture", "stock_script_h2": "How they don't collide.", "stock_voiceover": "Organized as one engineering company. Six tiers. Shared substrate keeps everyone in sync.", "show_echo_ribbon": true, "delivery_note": "Casual confirmation.", "tone_note": "builder explaining"},
    {"frame_id": "F7",    "position": 8,  "shape": "modal-live-json",      "act": "thrill", "time_start_seconds": 135, "duration_seconds": 35, "concept": "Act II · Socratic discovery", "stock_meta_tag": "act ii · socratic", "stock_script_h2": "Four clicks. Intent locked.", "stock_voiceover": "Four questions. That's it. <b>Now every advocate inherits the same truth.</b>", "show_echo_ribbon": true, "delivery_note": "Casual confidence.", "tone_note": "confident craftsman"},
    {"frame_id": "F8",    "position": 9,  "shape": "gallery-hero",         "act": "thrill", "time_start_seconds": 170, "duration_seconds": 40, "concept": "Act II climax · choice", "stock_meta_tag": "act ii climax · click one", "stock_script_h2": "Click one.", "stock_voiceover": "Twenty-six advocates in parallel. Pick the one that matches your gut. <b>Click one.</b>", "show_echo_ribbon": true, "delivery_note": "Showman + invitation.", "tone_note": "showman + invitation"},
    {"frame_id": "F9",    "position": 10, "shape": "triple-pane",          "act": "thrill", "time_start_seconds": 210, "duration_seconds": 50, "concept": "Act III · the work", "stock_meta_tag": "act iii · the work", "stock_script_h2": "The harness earns the score.", "stock_voiceover": "Now watch. Spec hashed. Locked. Five teams build. Five judges. Five auditors. Double-gate. <b>The harness self-corrects — until it earns the score.</b>", "show_echo_ribbon": true, "delivery_note": "Rapid-fire. Long pause before closer.", "tone_note": "live narration"},
    {"frame_id": "F10",   "position": 11, "shape": "terminal-browser",     "act": "thrill", "time_start_seconds": 260, "duration_seconds": 22, "concept": "Act III climax · launch", "stock_meta_tag": "act iii climax · click two", "stock_script_h2": "Click two. Done.", "stock_voiceover": "<b>Click two.</b> Done. The server launches itself. <b>Three minutes ago — this was one line.</b>", "show_echo_ribbon": true, "navbar_keys_label": "★ ACT III CLIMAX · the payoff", "delivery_note": "Drop the tool. Quiet awe.", "tone_note": "maker exhaling"},
    {"frame_id": "F11",   "position": 12, "shape": "repo-install",         "act": "outro",  "time_start_seconds": 282, "duration_seconds": 8,  "concept": "Act III close · reflection + repo", "stock_meta_tag": "act iii close · reflection", "stock_script_h2": "Apache-2.0. Two commands. Done.", "stock_voiceover": "Open source. Apache 2.0. Two commands to install. <b>{{hero_copy}}</b>", "show_echo_ribbon": true, "delivery_note": "Hero echo as closing word. Each syllable.", "tone_note": "arrival"},
    {"frame_id": "close", "position": 13, "shape": "close",                "act": "close",  "time_start_seconds": 290, "duration_seconds": 18, "concept": "Closing card", "stock_voiceover": "", "show_echo_ribbon": false, "delivery_note": "Long hold — the audience applauds.", "tone_note": "title-card close"}
  ],
  "ranges": {
    "opening": {"start_position": 2, "end_position": 5,  "label": "opening · Act I · 95s",   "button_label": "▶ Opening · Act I (95s)", "key": "o"},
    "full":    {"start_position": 2, "end_position": 12, "label": "full · 5 acts · 290s",    "button_label": "▶ Full · 5 acts (290s)",  "key": "f"}
  }
