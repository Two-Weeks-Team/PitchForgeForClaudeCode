  "beats": [
    {"frame_id": "cover", "position": 1,  "shape": "cover",                "act": "cover",  "time_start_seconds": 0,   "duration_seconds": 8,  "concept": "Title card", "stock_heading": "{{project_name}}", "stock_voiceover": "", "show_echo_ribbon": false, "delivery_note": "Hold the cover for 8s.", "tone_note": "title-card calm"},
    {"frame_id": "F1",    "position": 2,  "shape": "chain",                "act": "agro",   "time_start_seconds": 8,   "duration_seconds": 10, "concept": "Problem framing — chain ends in `?`", "stock_heading": "we don't know what we want.", "stock_heading_accent_word": "want.", "stock_meta_tag": "act i · the agro", "stock_script_h2": "We've been lying.", "stock_voiceover": "Here's the lie we tell every project: 'I know what I want.' You don't. <b>Not until you see it.</b>", "show_echo_ribbon": false, "delivery_note": "Open like prosecutor opening. No smile.", "tone_note": "prosecutor opening"},
    {"frame_id": "F2",    "position": 3,  "shape": "stack-strikethrough",  "act": "agro",   "time_start_seconds": 18,  "duration_seconds": 15, "concept": "Failure cascade — 5 strikethrough rows", "stock_heading": "every. single. time.", "stock_heading_accent_word": "time.", "stock_meta_tag": "act i · the indictment", "stock_script_h2": "Same blind spot.", "stock_voiceover": "Tests pass. Specs lock. Product wrong. <b>Every. Single. Time.</b>", "show_echo_ribbon": false, "delivery_note": "Drop pitch on each beat.", "tone_note": "indictment"},
    {"frame_id": "F3",    "position": 4,  "shape": "chain",                "act": "drop",   "time_start_seconds": 33,  "duration_seconds": 10, "concept": "Pivot — chain reverses", "stock_heading": "flip the order.", "stock_heading_accent_word": "flip", "stock_meta_tag": "act ii · the pivot", "stock_script_h2": "Result first.", "stock_voiceover": "So we flipped it. See the result <i>first</i> — before any spec. <b>The picture is the spec.</b>", "show_echo_ribbon": false, "delivery_note": "Then go quiet. Em-dash held breath.", "tone_note": "maker who figured it out"},
    {"frame_id": "F4",    "position": 5,  "shape": "gallery-hero",         "act": "drop",   "time_start_seconds": 43,  "duration_seconds": 25, "concept": "Hero gallery + paper-title hero copy", "stock_heading": "", "stock_voiceover": "Look. Twenty-six futures of your idea. Before any spec. <b>{{hero_copy}}</b>", "show_echo_ribbon": false, "navbar_keys_label": "★ DELAYED HERO · 25s hold · half-beat silence after", "delivery_note": "Read hero slowly. Each syllable.", "tone_note": "keynote reveal"},
    {"frame_id": "F5",    "position": 6,  "shape": "counter-roll",         "act": "thrill", "time_start_seconds": 68,  "duration_seconds": 6,  "concept": "Kick — number reveal", "stock_meta_tag": "act iii · the kick", "stock_script_h2": "The scale.", "stock_voiceover": "How? <b>{{counter_target}} {{counter_unit}}. One plugin. Two clicks.</b>", "show_echo_ribbon": true, "delivery_note": "Audience participation cue.", "tone_note": "rule-of-three confidence"},
    {"frame_id": "F6",    "position": 7,  "shape": "hierarchy-diagram",    "act": "thrill", "time_start_seconds": 74,  "duration_seconds": 22, "concept": "Architecture", "stock_meta_tag": "act iii · architecture", "stock_script_h2": "How they don't collide.", "stock_voiceover": "Organized as one engineering company. Six tiers. Shared substrate keeps everyone in sync.", "show_echo_ribbon": true, "delivery_note": "Casual confirmation.", "tone_note": "builder explaining"},
    {"frame_id": "F7",    "position": 8,  "shape": "modal-live-json",      "act": "thrill", "time_start_seconds": 96,  "duration_seconds": 22, "concept": "Socratic + live-filling JSON", "stock_meta_tag": "act iii · socratic", "stock_script_h2": "Four clicks. Intent locked.", "stock_voiceover": "Four questions. That's it. <b>Now every advocate inherits the same truth.</b>", "show_echo_ribbon": true, "delivery_note": "Casual confidence.", "tone_note": "confident craftsman"},
    {"frame_id": "F8",    "position": 9,  "shape": "gallery-hero",         "act": "thrill", "time_start_seconds": 118, "duration_seconds": 25, "concept": "Selection — gallery + click", "stock_meta_tag": "act iv · click one", "stock_script_h2": "Click one.", "stock_voiceover": "Twenty-six advocates in parallel. Pick the one. <b>Click one.</b>", "show_echo_ribbon": true, "delivery_note": "Showman + invitation.", "tone_note": "showman + invitation"},
    {"frame_id": "F9",    "position": 10, "shape": "triple-pane",          "act": "thrill", "time_start_seconds": 143, "duration_seconds": 22, "concept": "Build timelapse", "stock_meta_tag": "act iv · build + score", "stock_script_h2": "The harness earns the score.", "stock_voiceover": "Now watch. Spec hashed. Locked. Five teams build. Five judges. Five auditors. Double-gate. <b>The harness self-corrects — until it earns the score.</b>", "show_echo_ribbon": true, "delivery_note": "Rapid-fire fragments. Em-dash before closer.", "tone_note": "live narration"},
    {"frame_id": "F10",   "position": 11, "shape": "terminal-browser",     "act": "thrill", "time_start_seconds": 165, "duration_seconds": 8,  "concept": "Auto-launch payoff", "stock_meta_tag": "act v · click two", "stock_script_h2": "Click two. Done.", "stock_voiceover": "<b>Click two.</b> Done. The server launches itself. <b>Three minutes ago — this was one line.</b>", "show_echo_ribbon": true, "navbar_keys_label": "★ THE EMOTIONAL PAYOFF", "delivery_note": "Drop the tool. Quiet awe.", "tone_note": "maker exhaling"},
    {"frame_id": "F11",   "position": 12, "shape": "repo-install",         "act": "outro",  "time_start_seconds": 173, "duration_seconds": 5,  "concept": "Outro — repo + install + hero echo", "stock_meta_tag": "act v · outro", "stock_script_h2": "Apache-2.0. Two commands. Done.", "stock_voiceover": "Open source. Two commands to install. <b>{{hero_copy}}</b>", "show_echo_ribbon": true, "delivery_note": "Hero echo last. Each syllable.", "tone_note": "arrival"},
